# ============================================
# TEMPLATE FOR ENVIRONMENT VARIABLES
# Copy this file to .env and fill in your values
# ============================================

# Groq API Key (Get from: https://console.groq.com)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Telegram Bot Configuration (Get bot token from BotFather, chat ID from your chat)
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_chat_id_here

# Patient ID (For demo purposes)
PATIENT_ID=PT-2024-089

# ============================================
# MLFLOW / DAGSHUB CONFIGURATION (optional)
# ============================================
# Set true to load model/scalers from DagsHub MLflow artifacts
USE_MLFLOW=false

# Example: https://dagshub.com/<owner>/<repo>.mlflow
MLFLOW_TRACKING_URI=
MLFLOW_TRACKING_USERNAME=
MLFLOW_TRACKING_PASSWORD=

# Recommended: pull model directly from Model Registry (latest/stage)
# Example: models:/cardio-risk-cnnlstm/latest
MLFLOW_MODEL_URI=

# Optional: if you want to pull scalers from an MLflow run, set run id below
MLFLOW_RUN_ID=
MLFLOW_SCALER_DYN_ARTIFACT_PATH=scaler_dyn.pkl
MLFLOW_SCALER_STAT_ARTIFACT_PATH=scaler_stat.pkl
